# Copy this to .env and fill in your values
# At minimum, set ANTHROPIC_API_KEY for the strongest signal (Claude AI sentiment)

# --- Claude AI (highest-impact upgrade — enables LLM sentiment analysis) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Polymarket Trading (needed for live trading only) ---
POLYMARKET_PRIVATE_KEY=your_ethereum_private_key_here
POLYMARKET_API_KEY=your_clob_api_key
POLYMARKET_API_SECRET=your_clob_api_secret
POLYMARKET_API_PASSPHRASE=your_clob_passphrase

# --- Sports Data (api-sports.io — one key covers NHL/NBA/NFL/MLB) ---
SPORTS_API_KEY=your_api_sports_io_key
HOCKEY_API_KEY=your_hockey_api_key

# --- News (optional — falls back to Google News scraping) ---
NEWS_API_KEY=your_newsapi_org_key
